# Norvar Monitoring Agent - Environment Variables
# Add these to your Vercel project settings and .env.local for development.

# App URL used to build OAuth redirect URIs and webhook URLs.
NEXT_PUBLIC_APP_URL=https://norvar.io

# OAuth state signing for CSRF protection.
# Generate with: openssl rand -hex 32
MONITORING_OAUTH_STATE_SECRET=

# GitHub App
# Create at: https://github.com/organizations/YOUR_ORG/settings/apps/new
# Webhook URL:  https://norvar.io/api/monitor/github
# Setup URL:    https://norvar.io/api/monitor/oauth/github/callback
# Permissions:  Contents (read), Pull requests (read), Metadata (read)
# Subscribe to: push, pull_request
GITHUB_APP_SLUG=norvar-monitoring
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=

# GitLab OAuth Application
# Create at: https://gitlab.com/-/profile/applications
# Redirect URI: https://norvar.io/api/monitor/oauth/gitlab/callback
# Scopes:       api, read_repository
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# Jira / Atlassian OAuth 2.0 (3LO)
# Create at: https://developer.atlassian.com/console/myapps/
# Callback URL: https://norvar.io/api/monitor/oauth/jira/callback
# Scopes:       read:jira-work, manage:jira-webhook, offline_access
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# Existing Norvar env vars, listed for reference.
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# ANTHROPIC_API_KEY=
# RESEND_API_KEY=
# EMAIL_FROM=
